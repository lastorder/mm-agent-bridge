# Mattermost
MM_URL=localhost
MM_PORT=8065
MM_SCHEME=http
MM_TOKEN=<bot-personal-access-token>

# Bot
BOT_MENTION_NAME=ai-agent          # Mattermost username the bot listens to

# Agent backend: "opencode" (default) or "copilot"
AGENT_TYPE=opencode

# OpenCode - connect to an existing local session (used when AGENT_TYPE=opencode)
OPENCODE_BASE_URL=http://localhost:36000
OPENCODE_SESSION_ID=<existing-session-id>   # optional; creates new if empty/invalid
OPENCODE_MODEL_ID=<model-id>
OPENCODE_PROVIDER_ID=<provider-id>

# GitHub Copilot via github-copilot-sdk (used when AGENT_TYPE=copilot)
# Auth: install Copilot CLI and run `copilot` to login, OR set one of:
#   COPILOT_GITHUB_TOKEN, GH_TOKEN, or GITHUB_TOKEN
COPILOT_SESSION_ID=<existing-copilot-session-id>   # optional; creates new if empty/invalid
# COPILOT_MODEL=gpt-5.4

# Greeting / goodbye messages (optional, disabled by default)
# GREETING_ENABLED=true                             # true/1/yes to enable
# GREETING_CHANNEL_ID=<channel-id>                  # required when enabled
# GREETING_MESSAGE=Agent is now online and ready.   # custom startup message
# GOODBYE_MESSAGE=Agent is shutting down. Goodbye.  # custom shutdown message

# Bot reply messages (optional, defaults shown)
# MSG_QUEUED=Your request has been queued. Please wait...
# MSG_QUEUE_FULL=Agent is busy, please try again later.
# MSG_PROCESSING=Processing your request...
# MSG_ERROR=Sorry, an error occurred while processing your request.
# MSG_EMPTY=Empty message after removing mention.
# MSG_SHOW_HOST=false                               # true/1/yes to append host info to replies

# Queue settings (optional)
# QUEUE_MAX_SIZE=10                                 # max queued requests; excess are rejected

# Thread context (optional)
# THREAD_CONTEXT_MAX_MESSAGES=20                    # max previous messages to include as context
